{"vertex":"precision highp float;\n\n#include <GlobalFrameUniforms>\n\nin vec4 position;\nin vec4 color;\nin vec3 normal;\nin vec2 uv;\nin vec4 props1;\n\nout vec3 vColor;\nout vec3 vNormal;\nout vec2 vUv;\nout vec4 vProps1;\nout vec3 vViewPosition;\nout vec3 vWorldPosition;\nflat out int vInstanceId;\n\n#include <InstancingPars>\n#include <SkinningPars>\n#include <ShadowPars>\n\nvoid main() {\n\tvec4 transformedPosition = position;\n\n\t#include <Position>\n\n\t#include <Instancing>\n\n\t#include <Shadow>\n\n    vViewPosition = normalize(cameraPosition - transformedPosition.xyz);\n    vProps1 = props1;\n    vWorldPosition = transformedPosition.xyz;\n    vColor = color.rgb;\n    vUv = uv;\n}","fragment":"precision mediump float;\n\n#include <DefinesPars>\n#include <GlobalFrameUniforms.vert>\n\nin vec3 vNormal;\nin vec2 vUv;\nin vec4 vProps1;\nin vec3 vViewPosition;\nin vec3 vWorldPosition;\nin vec3 vColor;\nflat in int vInstanceId;\n\nout vec4 fragmentColor;\n\n#include <ToonGradientPars>\n#include <FogPars>\n#include <FbmPars>\n#include <Sh3CoefficentsPars>\n#include <ShadowPars>\n\nvoid main() {\n  // Center point for the portal\n  vec2 center = vec2(0.5, 0.5);\n  vec2 delta = vUv - center;\n  \n  // Calculate distance and angle from original UVs\n  float dist = length(delta);\n  float angle = atan(delta.y, delta.x);\n  \n  // Create a consistent spiral pattern using logarithmic distance\n  // This keeps the spiral bands uniform width across the entire portal\n  float spiralPattern = angle * 2.0 + log(dist * 2.0 + 0.1) * 8.0 - time * 2.0;\n  float spiral = sin(spiralPattern) * 0.5 + 0.5;\n  \n  // Create pulsing rings that move outward\n  float rings = sin(dist * 10.0 - time * 3.0) * 0.5 + 0.5;\n  \n  // Combine patterns - favor the spiral more\n  float pattern = mix(rings, spiral, 0.7);\n  \n  // Apply toon gradient based on pattern\n  float toonStep = floor(pattern * 4.0) / 4.0;\n  \n  // Use vertex color as base color\n  vec3 diffuse = vColor * (0.5 + toonStep 