{"vertex":"#include <GlobalFrameUniforms>\n\nin vec3 position;\nin vec2 uv;\n\nout vec2 vUv;\n\nvoid main() {\n  vUv = uv;\n  gl_Position = transformationProjectionMatrix * vec4(position, 1.0);\n}\n","fragment":"precision mediump float;\n\n#include <GlobalFrameUniforms.vert>\n\nin vec2 vUv;\n\nuniform sampler2D boostpad;\n\n#define scrollSpeed 2.0\n\nout vec4 fragmentColor;\n\nvoid main() { \n  // Fix upside-down texture by flipping V coordinate\n  vec2 correctedUV = vec2(vUv.x, 1.0 - vUv.y);\n  \n  // Create scrolling UV\n  vec2 scrollUV = vec2(correctedUV.x, fract(correctedUV.y * 2.0 - time * scrollSpeed));\n\n  // Producing a highly saturated rainbow effect based on time and UVs\n  float phase = correctedUV.y * 2.0 * 3.14159; // Multiply by 2PI for a full cycle over [0,1]\n  float red = sin(time + phase) * 0.5 + 0.5;\n  float green = sin(time + phase + 2.0) * 0.5 + 0.5;\n  float blue = sin(time + phase + 4.0) * 0.5 + 0.5;\n  vec3 rainbowColor = vec3(red, green, blue);\n  // Much more saturated - reduced gray mixing from 0.6 to 0.1\n  vec3 tonedColor = mix(rainbowColor, vec3(0.5, 0.5, 0.5), 0.1);\n\n  // Sample the texture\n  vec4 texColor = texture(boostpad, scrollUV);\n  \n  fragmentColor.rgb = texColor.rgb * tonedColor;\n  fragmentColor.a = 1.0;\n}","blending":{"enabled":false,"src":770,"dst":771,"srcAlpha":772,"dstAlpha":770,"equation":32774,"equationAlpha":32774}}